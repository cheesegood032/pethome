{"remainingRequest":"D:\\Assign\\pethome\\pethome\\pethome0614\\pethome-main\\pethome-main\\pet-home\\frontend\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\Assign\\pethome\\pethome\\pethome0614\\pethome-main\\pethome-main\\pet-home\\frontend\\src\\views\\admin\\ShopOrderManage.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\Assign\\pethome\\pethome\\pethome0614\\pethome-main\\pethome-main\\pet-home\\frontend\\src\\views\\admin\\ShopOrderManage.vue","mtime":1781444653567},{"path":"D:\\Assign\\pethome\\pethome\\pethome0614\\pethome-main\\pethome-main\\pet-home\\frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1780590228000},{"path":"D:\\Assign\\pethome\\pethome\\pethome0614\\pethome-main\\pethome-main\\pet-home\\frontend\\node_modules\\vue-loader\\lib\\index.js","mtime":1780590228000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["ShopOrderManage.vue"],"names":[],"mappings":";AAuCA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"ShopOrderManage.vue","sourceRoot":"src/views/admin","sourcesContent":["<template>\n  <div class=\"admin-orders\">\n    <div class=\"toolbar\">\n      <el-select v-model=\"filterStatus\" placeholder=\"订单状态\" clearable>\n        <el-option label=\"全部\" :value=\"null\"></el-option>\n        <el-option label=\"未支付\" :value=\"1\"></el-option>\n        <el-option label=\"待发货\" :value=\"2\"></el-option>\n        <el-option label=\"已发货\" :value=\"3\"></el-option>\n        <el-option label=\"已签收\" :value=\"4\"></el-option>\n      </el-select>\n      <el-input v-model=\"searchKeyword\" placeholder=\"搜索订单号/用户名\" @keyup.enter.native=\"handleSearch\" class=\"search-input\"></el-input>\n    </div>\n\n    <el-table :data=\"orders\" border class=\"order-table\">\n      <el-table-column prop=\"order_no\" label=\"订单号\"></el-table-column>\n      <el-table-column prop=\"username\" label=\"用户\"></el-table-column>\n      <el-table-column prop=\"receiver_phone\" label=\"手机号\"></el-table-column>\n      <el-table-column prop=\"total_price\" label=\"金额\" width=\"100\">\n        <template slot-scope=\"scope\">¥{{ scope.row.total_price }}</template>\n      </el-table-column>\n      <el-table-column prop=\"status\" label=\"状态\" width=\"100\">\n        <template slot-scope=\"scope\">\n          <el-tag :type=\"getStatusType(scope.row.status)\">{{ getStatusText(scope.row.status) }}</el-tag>\n        </template>\n      </el-table-column>\n      <el-table-column prop=\"create_time\" label=\"创建时间\" width=\"180\">\n        <template slot-scope=\"scope\">{{ formatTime(scope.row.create_time) }}</template>\n      </el-table-column>\n      <el-table-column label=\"操作\" width=\"150\">\n        <template slot-scope=\"scope\">\n          <el-button v-if=\"scope.row.status === 2\" type=\"primary\" size=\"small\" @click=\"handleShip(scope.row.id)\">发货</el-button>\n          <el-button type=\"text\" @click=\"handleDetail(scope.row.id)\">详情</el-button>\n        </template>\n      </el-table-column>\n    </el-table>\n  </div>\n</template>\n\n<script>\nimport { getAdminOrderList, shipOrder } from '@/api/order'\nimport { Message } from 'element-ui'\n\nexport default {\n  name: 'AdminOrders',\n  data() {\n    return {\n      orders: [],\n      filterStatus: null,\n      searchKeyword: ''\n    }\n  },\n  mounted() {\n    this.fetchOrders()\n  },\n  methods: {\n    async fetchOrders() {\n      try {\n        const params = {}\n        if (this.filterStatus !== null) params.status = this.filterStatus\n        const res = await getAdminOrderList(params)\n        this.orders = res.data.list || res.data\n      } catch (e) {\n        console.error(e)\n      }\n    },\n    handleSearch() {\n      this.fetchOrders()\n    },\n    getStatusText(status) {\n      const map = { 1: '未支付', 2: '待发货', 3: '已发货', 4: '已签收' }\n      return map[status] || '未知'\n    },\n    getStatusType(status) {\n      const map = { 1: 'warning', 2: 'primary', 3: 'success', 4: 'info' }\n      return map[status] || 'default'\n    },\n    formatTime(timeStr) {\n      if (!timeStr) return ''\n      const date = new Date(timeStr)\n      return date.toLocaleString('zh-CN')\n    },\n    async handleShip(orderId) {\n      try {\n        await shipOrder(orderId)\n        Message.success('发货成功')\n        this.fetchOrders()\n      } catch (e) {\n        console.error(e)\n      }\n    },\n    handleDetail(orderId) {\n      this.$message.info('订单详情: ' + orderId)\n    }\n  },\n  watch: {\n    filterStatus() {\n      this.fetchOrders()\n    }\n  }\n}\n</script>\n\n<style scoped>\n.admin-orders {\n  background: white;\n  border-radius: 12px;\n  padding: 20px;\n}\n\n.toolbar {\n  display: flex;\n  gap: 16px;\n  margin-bottom: 20px;\n}\n\n.search-input {\n  width: 300px;\n}\n</style>\n"]}]}