{"remainingRequest":"D:\\学校学习文件\\web技术\\github-new\\pethome\\pethome0614\\pethome-main\\pethome-main\\pet-home\\frontend\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\学校学习文件\\web技术\\github-new\\pethome\\pethome0614\\pethome-main\\pethome-main\\pet-home\\frontend\\src\\views\\admin\\ShopOrderManage.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\学校学习文件\\web技术\\github-new\\pethome\\pethome0614\\pethome-main\\pethome-main\\pet-home\\frontend\\src\\views\\admin\\ShopOrderManage.vue","mtime":1781710967269},{"path":"D:\\学校学习文件\\web技术\\github-new\\pethome\\pethome0614\\pethome-main\\pethome-main\\pet-home\\frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1781710963447},{"path":"D:\\学校学习文件\\web技术\\github-new\\pethome\\pethome0614\\pethome-main\\pethome-main\\pet-home\\frontend\\node_modules\\vue-loader\\lib\\index.js","mtime":1781710966904}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["ShopOrderManage.vue"],"names":[],"mappings":";AAuDA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"ShopOrderManage.vue","sourceRoot":"src/views/admin","sourcesContent":["<template>\r\n  <div class=\"admin-orders\">\r\n    <div class=\"toolbar\">\r\n      <el-select v-model=\"filterStatus\" placeholder=\"订单状态\" clearable>\r\n        <el-option label=\"全部\" :value=\"null\"></el-option>\r\n        <el-option label=\"未支付\" :value=\"1\"></el-option>\r\n        <el-option label=\"待发货\" :value=\"2\"></el-option>\r\n        <el-option label=\"已发货\" :value=\"3\"></el-option>\r\n        <el-option label=\"已签收\" :value=\"4\"></el-option>\r\n      </el-select>\r\n      <el-input v-model=\"searchKeyword\" placeholder=\"搜索订单号/用户名\" @keyup.enter.native=\"handleSearch\" class=\"search-input\"></el-input>\r\n    </div>\r\n\r\n    <el-table :data=\"orders\" border class=\"order-table\">\r\n      <el-table-column prop=\"order_no\" label=\"订单号\"></el-table-column>\r\n      <el-table-column prop=\"username\" label=\"用户\"></el-table-column>\r\n      <el-table-column prop=\"receiver_phone\" label=\"手机号\"></el-table-column>\r\n      <el-table-column prop=\"total_price\" label=\"金额\" width=\"100\">\r\n        <template slot-scope=\"scope\">¥{{ scope.row.total_price }}</template>\r\n      </el-table-column>\r\n      <el-table-column prop=\"status\" label=\"状态\" width=\"100\">\r\n        <template slot-scope=\"scope\">\r\n          <el-tag :type=\"getStatusType(scope.row.status)\">{{ getStatusText(scope.row.status) }}</el-tag>\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column prop=\"create_time\" label=\"创建时间\" width=\"180\">\r\n        <template slot-scope=\"scope\">{{ formatTime(scope.row.create_time) }}</template>\r\n      </el-table-column>\r\n      <el-table-column label=\"操作\" width=\"150\">\r\n        <template slot-scope=\"scope\">\r\n          <el-button v-if=\"scope.row.status === 2\" type=\"primary\" size=\"small\" @click=\"handleShip(scope.row.id)\">发货</el-button>\r\n          <el-button type=\"text\" @click=\"handleDetail(scope.row.id)\">详情</el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n    <!-- 订单详情弹窗 -->\r\n    <el-dialog title=\"订单详情\" :visible.sync=\"detailVisible\" width=\"600px\">\r\n      <div v-if=\"currentOrder\">\r\n        <p><strong>订单号：</strong>{{ currentOrder.order_no }}</p>\r\n        <p><strong>收货人：</strong>{{ currentOrder.receiver_name }} ({{ currentOrder.receiver_phone }})</p>\r\n        <p><strong>地址：</strong>{{ currentOrder.receiver_address }}</p>\r\n        <p><strong>总金额：</strong>¥{{ currentOrder.total_price }}</p>\r\n        <p><strong>备注：</strong>{{ currentOrder.remark || '无' }}</p>\r\n        <el-table :data=\"currentOrder.items\" border size=\"small\" style=\"margin-top: 15px;\">\r\n          <el-table-column prop=\"product_name\" label=\"商品名称\"></el-table-column>\r\n          <el-table-column prop=\"spec\" label=\"规格\" width=\"100\"></el-table-column>\r\n          <el-table-column prop=\"price\" label=\"单价\" width=\"80\"></el-table-column>\r\n          <el-table-column prop=\"quantity\" label=\"数量\" width=\"80\"></el-table-column>\r\n        </el-table>\r\n      </div>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { getAdminOrderList, shipOrder, getOrderDetail } from '@/api/order'\r\nimport { Message } from 'element-ui'\r\n\r\nexport default {\r\n  name: 'AdminOrders',\r\n  data() {\r\n    return {\r\n      orders: [],\r\n      filterStatus: null,\r\n      searchKeyword: '',\r\n      detailVisible: false,\r\n      currentOrder: null\r\n    }\r\n  },\r\n  mounted() {\r\n    this.fetchOrders()\r\n  },\r\n  methods: {\r\n    async fetchOrders() {\r\n      try {\r\n        const params = {}\r\n        if (this.filterStatus !== null) params.status = this.filterStatus\r\n        const res = await getAdminOrderList(params)\r\n        this.orders = res.data.list || res.data\r\n      } catch (e) {\r\n        console.error(e)\r\n      }\r\n    },\r\n    handleSearch() {\r\n      this.fetchOrders()\r\n    },\r\n    getStatusText(status) {\r\n      const map = { 1: '未支付', 2: '待发货', 3: '已发货', 4: '已签收' }\r\n      return map[status] || '未知'\r\n    },\r\n    getStatusType(status) {\r\n      const map = { 1: 'warning', 2: 'primary', 3: 'success', 4: 'info' }\r\n      return map[status] || 'default'\r\n    },\r\n    formatTime(timeStr) {\r\n      if (!timeStr) return ''\r\n      const date = new Date(timeStr)\r\n      return date.toLocaleString('zh-CN')\r\n    },\r\n    async handleShip(orderId) {\r\n      try {\r\n        await shipOrder(orderId)\r\n        Message.success('发货成功')\r\n        this.fetchOrders()\r\n      } catch (e) {\r\n        console.error(e)\r\n      }\r\n    },\r\n    async handleDetail(orderId) {\r\n      try {\r\n        const res = await getOrderDetail(orderId)\r\n        this.currentOrder = res.data\r\n        this.detailVisible = true\r\n      } catch (e) {\r\n        console.error(e)\r\n      }\r\n    }\r\n  },\r\n  watch: {\r\n    filterStatus() {\r\n      this.fetchOrders()\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.admin-orders {\r\n  background: white;\r\n  border-radius: 12px;\r\n  padding: 20px;\r\n}\r\n\r\n.toolbar {\r\n  display: flex;\r\n  gap: 16px;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.search-input {\r\n  width: 300px;\r\n}\r\n</style>\r\n"]}]}