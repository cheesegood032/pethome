=\"form.breed\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"年龄\">\n            <el-input v-model=\"form.age\" type=\"number\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"性别\">\n            <el-select v-model=\"form.gender\">\n              <el-option label=\"公\" value=\"公\"></el-option>\n              <el-option label=\"母\" value=\"母\"></el-option>\n            </el-select>\n          </el-form-item>\n          <el-form-item label=\"体重(kg)\">\n            <el-input v-model=\"form.weight\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"健康状况\">\n            <el-input v-model=\"form.healthStatus\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"备注\">\n            <el-input type=\"textarea\" v-model=\"form.remark\"></el-input>\n          </el-form-item>\n          <el-form-item>\n            <el-button type=\"primary\" @click=\"handleSubmit\">添加</el-button>\n            <el-button @click=\"goBack\">取消</el-button>\n          </el-form-item>\n        </el-form>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { addPet } from '@/api/pet'\nimport { Message } from 'element-ui'\n\nexport default {\n  name: 'PetAdd',\n  data() {\n    return {\n      form: {\n        name: '',\n        species: '',\n        breed: '',\n        age: null,\n        gender: '',\n        weight: null,\n        healthStatus: '',\n        remark: ''\n      }\n    }\n  },\n  methods: {\n    async handleSubmit() {\n      if (!this.form.name || !this.form.species) {\n        Message.error('请填写必填项')\n        return\n      }\n      try {\n        await addPet(this.form)\n        Message.success('添加成功')\n        this.$router.push('/pets')\n      } catch (e) {\n        console.error(e)\n      }\n    },\n    goBack() {\n      this.$router.push('/pets')\n    }\n  }\n}\n</script>\n\n<style scoped>\n.pet-add-page {\n  background: #faf8f5;\n  min-height: calc(100vh - 140px);\n  padding: 30px 0;\n}\n\n.container {\n  max-width: 500px;\n  margin: 0 auto;\n  padding: 0 20px;\n}\n\n.form-card {\n  background: white;\n  border-radius: 12px;\n  padding: 30px;\n}\n\n.form-card h2 {\n  font-size: 22px;\n  margin-bottom: 24px;\n}\n</style>\n"]}]}